datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// SQLite dev: enum replaced with String
// enum CommunicationType { SMS EMAIL }
// enum LogStatus { SENT FAILED }

model User {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  name      String   @default("")

  customers           Customer[]
  logs                CommunicationLog[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Customer {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  name      String
  address   String?
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs CommunicationLog[]
}

model CommunicationLog {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt
  customerId BigInt

  type       String
  subject    String?
  message    String
  status     String

  sentAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([userId])
}