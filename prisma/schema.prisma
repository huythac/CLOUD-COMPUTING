datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        BigInt   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  customers Customer[]
}

model Customer {
  id        BigInt   @id @default(autoincrement())
  user_id   BigInt
  name      String
  address   String?
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [user_id], references: [id])
}